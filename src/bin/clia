#!/usr/bin/env bash
# clia - gestion des sessions et inspection des ressources livrables.
#
# Usage :
#   clia [-h|--help]              affiche cette aide
#   clia --man                    aide au format manpage
#   clia --version [--long]       version métier (--long : tous les ensembles)
#   clia --config                 chemins de travail détectés
#   clia res ls [PREFIX] [opts]   inspecte les ressources livrables
#   clia ses <cmd> [args]         gère les sessions (status, check, plan, open, close, new)
set -euo pipefail

CLIA_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIA_SRC="$(dirname "$CLIA_BIN")"
CLIA_LIB="$CLIA_SRC/lib"
REPO_ROOT="$(dirname "$CLIA_SRC")"

# Chemins de travail (structure de méthode, sans information de domaine).
DEV_DIR="$REPO_ROOT/.dev"
LOGS_DIR="$REPO_ROOT/logs/ia-output"
SESSIONS_DIR="$DEV_DIR/sessions"
SESSION_FILE="$DEV_DIR/session.md"
TEMPLATE_FILE="$DEV_DIR/templates/session.template.md"
RESSOURCES_FILE="$DEV_DIR/ressources.yaml"
VERSION_FILE="$REPO_ROOT/version.yaml"

# shellcheck source=../lib/common.sh
. "$CLIA_LIB/common.sh"
# shellcheck source=../lib/version.sh
. "$CLIA_LIB/version.sh"
# shellcheck source=../lib/resource.sh
. "$CLIA_LIB/resource.sh"
# shellcheck source=../lib/session.sh
. "$CLIA_LIB/session.sh"

_cleanup() { :; }
trap '_cleanup' EXIT

# _usage : imprime l'aide courte (extraite de l'en-tête du fichier).
_usage() {
  sed -n '2,9p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

# _man : aide au format manpage minimal.
_man() {
  cat <<'MAN'
NOM
    clia - gestion des sessions et inspection des ressources livrables

SYNOPSIS
    clia [-h|--help] [--man] [--version [--long]] [--config]
    clia res ls [PREFIX] [--version|--long]
    clia ses <status|check|plan|open|close|new> [args]

DESCRIPTION
    clia est un CLI déterministe qui prend en charge les transitions
    d'état du cycle de vie des sessions et l'inspection des ressources
    livrables et de leurs versions (voir ADR-006, ADR-007).

COMMANDES
    --version [--long]  version du domaine métier ; --long ajoute les
                        versions des ensembles vivants.
    --config            racine détectée et chemins de travail.
    res ls [PREFIX]     types de ressources connus, ou instances d'un
                        type (ID | STATE | VERSION).
    ses status          session active ? nombre d'archives.
    ses check           valide session.md contre SPEC-003.
    ses plan [x<SEQ>]   crée une session en planification.
    ses open [x<SEQ>]   ouvre une session (erreur si déjà active).
    ses close [SLUG]    archive la session active.
    ses new [x<SEQ>]    ferme puis ouvre une session.

CODES DE SORTIE
    0  succès   1  erreur applicative   2  erreur d'usage
MAN
}

# cmd_config : chemins de travail résolus.
cmd_config() {
  printf '%-18s %s\n' "repo-root" "$REPO_ROOT"
  printf '%-18s %s\n' "dev-dir" "$DEV_DIR"
  printf '%-18s %s\n' "logs-dir" "$LOGS_DIR"
  printf '%-18s %s\n' "sessions-dir" "$SESSIONS_DIR"
  printf '%-18s %s\n' "session-file" "$SESSION_FILE"
  printf '%-18s %s\n' "template" "$TEMPLATE_FILE"
  printf '%-18s %s\n' "ressources" "$RESSOURCES_FILE"
  printf '%-18s %s\n' "version-file" "$VERSION_FILE"
}

main() {
  case "${1:-}" in
    -h|--help|"") _usage; exit 0 ;;
    --man)        _man; exit 0 ;;
    --version)    shift; cmd_version "${1:-}"; exit 0 ;;
    --config)     cmd_config; exit 0 ;;
    res|resource) shift; cmd_res "$@" ;;
    ses|session)  shift; cmd_ses "$@" ;;
    *)            _err "commande inconnue : ${1}"; _usage >&2; exit 2 ;;
  esac
}

# N'exécute main que si le fichier est lancé, pas sourcé (SPEC-001).
[ "$0" != "${BASH_SOURCE[0]}" ] || main "$@"
