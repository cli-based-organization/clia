#!/usr/bin/env bash
# clia - gestion des sessions et inspection des ressources livrables.
# Aide et documentation générées à la volée depuis src/clia.doc.yaml
# (voir src/lib/doc.sh). Grammaire : clia [GLOBAL_OPTIONS] COMMAND|GROUP
# [OPTIONS]. Voir SPEC-002, REQ-002.
set -euo pipefail

CLIA_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLIA_SRC="$(dirname "$CLIA_BIN")"
CLIA_LIB="$CLIA_SRC/lib"
REPO_ROOT="$(dirname "$CLIA_SRC")"

# Chemins de travail (structure de méthode, sans information de domaine).
DEV_DIR="$REPO_ROOT/.dev"
LOGS_DIR="$REPO_ROOT/logs/ia-output"
SESSIONS_DIR="$DEV_DIR/sessions"
SESSION_FILE="$DEV_DIR/session.md"
TEMPLATE_FILE="$DEV_DIR/templates/session.template.md"
RESSOURCES_FILE="$DEV_DIR/ressources.yaml"
VERSION_FILE="$REPO_ROOT/version.yaml"
DOC_FILE="$CLIA_SRC/clia.doc.yaml"

# Options globales (grammaire clia [GLOBAL_OPTIONS] COMMAND [OPTIONS]).
DEBUG=0
DRY_RUN=0

# shellcheck source=../lib/common.sh
. "$CLIA_LIB/common.sh"
# shellcheck source=../lib/version.sh
. "$CLIA_LIB/version.sh"
# shellcheck source=../lib/resource.sh
. "$CLIA_LIB/resource.sh"
# shellcheck source=../lib/session.sh
. "$CLIA_LIB/session.sh"
# shellcheck source=../lib/doc.sh
. "$CLIA_LIB/doc.sh"

_cleanup() { :; }
trap '_cleanup' EXIT

# cmd_config : chemins de travail résolus.
cmd_config() {
  printf '%-18s %s\n' "repo-root" "$REPO_ROOT"
  printf '%-18s %s\n' "dev-dir" "$DEV_DIR"
  printf '%-18s %s\n' "logs-dir" "$LOGS_DIR"
  printf '%-18s %s\n' "sessions-dir" "$SESSIONS_DIR"
  printf '%-18s %s\n' "session-file" "$SESSION_FILE"
  printf '%-18s %s\n' "template" "$TEMPLATE_FILE"
  printf '%-18s %s\n' "ressources" "$RESSOURCES_FILE"
  printf '%-18s %s\n' "version-file" "$VERSION_FILE"
}

main() {
  # 1) Options globales, traitées avant le dispatch (REQ-001-F10).
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help|"") _doc_help; exit 0 ;;
      --man)        _doc_man;  exit 0 ;;
      --version)    shift; cmd_version "${1:-}"; exit 0 ;;
      --config)     cmd_config; exit 0 ;;
      --debug)      DEBUG=1; shift ;;
      --dry-run)    DRY_RUN=1; shift ;;
      --)           shift; break ;;
      -*)           _err "option globale inconnue : $1"; _doc_help >&2; exit 2 ;;
      *)            break ;;
    esac
  done
  [ $# -gt 0 ] || { _doc_help; exit 0; }

  # 2) Dispatch validé contre la source documentaire (cohérence, REQ-001-F9).
  local raw="$1"; shift
  local cmd; cmd="$(_doc_canon "$raw")"
  _doc_commands | grep -qx "$cmd" || { _err "commande inconnue : $raw"; _doc_help >&2; exit 2; }
  _dbg "dispatch cmd=$cmd dry_run=$DRY_RUN args=$*"
  case "$cmd" in
    res) cmd_res "$@" ;;
    ses) cmd_ses "$@" ;;
    *)   _die "commande sans handler : $cmd" 2 ;;
  esac
}

# N'exécute main que si le fichier est lancé, pas sourcé (SPEC-001).
[ "$0" != "${BASH_SOURCE[0]}" ] || main "$@"
